{
  "tests": [
    {
      "name": "Часть 1: Базовые операции (30 баллов)",
      "run": "./gradlew test --tests ru.hse.CalculatorTest.testAdd* --tests ru.hse.CalculatorTest.testSubtract* --tests ru.hse.CalculatorTest.testMultiply*",
      "points": 30,
      "timeout": 60,
      "description": "Тестирование сложения, вычитания и умножения"
    },
    {
      "name": "Часть 2: Деление и обработка ошибок (20 баллов)",
      "run": "./gradlew test --tests ru.hse.CalculatorTest.testDivide*",
      "points": 20,
      "timeout": 45,
      "description": "Тестирование деления и обработки деления на ноль"
    },
    {
      "name": "Часть 3: Логические операции (15 баллов)",
      "run": "./gradlew test --tests ru.hse.CalculatorTest.testIsEven --tests ru.hse.CalculatorTest.testMax",
      "points": 15,
      "timeout": 30,
      "description": "Тестирование проверки четности и поиска максимума"
    },
    {
      "name": "Часть 4: Параметризованные тесты (15 баллов)",
      "run": "./gradlew test --tests ru.hse.CalculatorTest.testAddParameterized --tests ru.hse.CalculatorTest.testSubtractParameterized",
      "points": 15,
      "timeout": 30,
      "description": "Тестирование с различными входными данными"
    },
    {
      "name": "Часть 5: Производительность (5 баллов)",
      "run": "./gradlew test --tests ru.hse.CalculatorTest.testPerformance",
      "points": 5,
      "timeout": 5,
      "description": "Проверка производительности базовых операций"
    }
  ]
}